# ─────────────────────────────────────────────────────────────────────────────
# Scout by ClientBloom — Environment Variables
#
# Copy this file to .env.local and fill in all values before running locally.
# Never commit .env.local or any file containing real credentials.
#
# Production: set these in Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────


# ── Airtable ──────────────────────────────────────────────────────────────────

# Token for the platform Airtable base (holds all Tenant records).
# Scopes required: data.records:read, data.records:write, schema.bases:read
PLATFORM_AIRTABLE_TOKEN=

# Base ID of the platform Airtable base (format: appXXXXXXXXXXXXXX)
# This is the same base that holds all customer data tables.
PLATFORM_AIRTABLE_BASE_ID=

# Provisioning token used for writes to customer data tables (Captured Posts, Sources, etc.)
# Can be the same token as PLATFORM_AIRTABLE_TOKEN if using a single base.
AIRTABLE_PROVISIONING_TOKEN=


# ── NextAuth ──────────────────────────────────────────────────────────────────

# Random secret used to sign JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of this deployment (no trailing slash).
# Local: http://localhost:3000
# Production: https://scout.clientbloom.ai
NEXTAUTH_URL=

# Public base URL used in email links and redirects (must match NEXTAUTH_URL).
NEXT_PUBLIC_BASE_URL=


# ── Apify ─────────────────────────────────────────────────────────────────────

# Platform-wide Apify API token. Used as the shared scanning pool.
# Tenants can override this with their own key via the Tenants.Apify API Key field.
# Get this from: apify.com → Settings → Integrations → Personal API tokens
APIFY_API_TOKEN=


# ── Anthropic ─────────────────────────────────────────────────────────────────

# Used to score posts via Claude (claude-haiku-4-5-20251001).
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=


# ── Resend (email) ────────────────────────────────────────────────────────────

# API key for transactional email delivery.
# Senders used: info@clientbloom.ai (trial emails, password reset, admin alerts)
# Get this from: resend.com → API Keys
RESEND_API_KEY=

# Admin email address for internal notifications (new trial signups, etc.)
ADMIN_EMAIL=


# ── Stripe (billing) ─────────────────────────────────────────────────────────

# Publishable key — safe to expose in client-side code.
# Get from: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key — never expose in client-side code.
STRIPE_SECRET_KEY=

# Webhook signing secret — used to verify incoming Stripe events.
# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Required in production. For local testing, use the Stripe CLI:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# Price IDs for each Scout plan (from Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=


# ── Cron security ─────────────────────────────────────────────────────────────

# Bearer token that protects all /api/cron/* routes from unauthorized execution.
# Generate with: openssl rand -base64 32
# Must match the Authorization header sent by Vercel Cron: "Bearer <CRON_SECRET>"
CRON_SECRET=


# ── Single-tenant fallback (legacy) ──────────────────────────────────────────
# These are only used if PLATFORM_AIRTABLE_BASE_ID is not set, which enables
# single-tenant mode for the original deployment. Not needed for new installs.

# ADMIN_EMAIL=
# ADMIN_PASSWORD=          (bcrypt hash of the admin password)
# AIRTABLE_API_TOKEN=
# AIRTABLE_BASE_ID=
